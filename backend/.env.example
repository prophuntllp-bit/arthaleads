# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/realestate_crm
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/realestate_crm
MONGO_URI=mongodb://localhost:27017/realestate_crm

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: run  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_very_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ── Field encryption (Automation.accessToken / userToken) ────────────────────
# Required in production — must be exactly 64 hex characters (32 bytes).
# Generate one: run  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this, saving any Facebook automation connection will fail.
CRYPTO_KEY=change_this_to_a_64_character_hex_string_in_production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CLIENT_URLS=http://localhost:3000,http://localhost:5173

# ── Facebook Webhook ──────────────────────────────────────────────────────────
FB_VERIFY_TOKEN=my_facebook_verify_token
FB_PAGE_ACCESS_TOKEN=your_page_access_token
FB_APP_ID=your_meta_app_id
FB_APP_SECRET=your_meta_app_secret
FB_REDIRECT_URI=http://localhost:5000/api/automations/facebook/callback
FRONTEND_URL=http://localhost:3000

# ── Email / Resend (HTTP API — no SMTP, works on Railway) ────────────────────
# Sign up free at resend.com → API Keys → Create API Key
RESEND_API_KEY=re_your_api_key_here
# Once you verify arthaleads.com domain in Resend, change this to:
# SMTP_FROM=Arthaleads <noreply@arthaleads.com>
# Until then, Resend sandbox only sends to your own verified email:
SMTP_FROM=Arthaleads <onboarding@resend.dev>

# ── Sentry (error monitoring) ────────────────────────────────────────────────
# Get DSN from sentry.io → your project → Settings → Client Keys
SENTRY_DSN=https://xxxx@oxxxx.ingest.us.sentry.io/xxxx

# ── Backup ───────────────────────────────────────────────────────────────────
# Email address that receives the daily gzipped DB backup
BACKUP_EMAIL=your@email.com

# ── Cloudinary (logo CDN) ────────────────────────────────────────────────────
# Sign up free at cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max requests per 15 minutes per IP (for auth endpoints)
RATE_LIMIT_AUTH=20
# Max requests per 15 minutes per IP (for general endpoints)
RATE_LIMIT_GENERAL=200
